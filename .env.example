# ============================================
# FNTickets - Variables de Entorno
# ============================================
# Copia este archivo como .env y configura tus valores

# Modo de la aplicación: development | production
NODE_ENV=development

# URL base de la API (para futura integración con backend)
# VITE_API_URL=http://localhost:3000/api

# Configuración de Email (para notificaciones)
# VITE_EMAIL_SERVICE=sendgrid
# VITE_EMAIL_API_KEY=tu_api_key_aqui

# Configuración de almacenamiento
# VITE_STORAGE_TYPE=local

# Configuración de autenticación JWT (futuro)
# VITE_JWT_SECRET=tu_secreto_jwt
# VITE_JWT_EXPIRES_IN=24h
